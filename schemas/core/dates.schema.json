{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dates.schema.json",
  "title": "Date types",
  "description": "Quarter, reporting period, date range, and UTC date-time types",
  "$defs": {
    "UtcDateTime": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$",
      "description": "ISO 8601 date-time in UTC. Must end with 'Z'. Example: '2024-06-15T14:30:00Z'"
    },
    "Quarter": {
      "type": "object",
      "description": "A fiscal quarter",
      "properties": {
        "year": {
          "type": "integer",
          "minimum": 1900,
          "maximum": 2100
        },
        "quarter": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        }
      },
      "required": ["year", "quarter"]
    },
    "ReportingPeriod": {
      "type": "object",
      "description": "A reporting period with start/end dates and optional quarter",
      "properties": {
        "start_date": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 date, e.g. '2024-06-15'"
        },
        "end_date": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 date, e.g. '2024-06-15'"
        },
        "quarter": {
          "$ref": "#/$defs/Quarter"
        }
      },
      "required": ["start_date", "end_date"]
    },
    "DateRange": {
      "type": "object",
      "description": "An arbitrary date range",
      "properties": {
        "start_date": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 date, e.g. '2024-06-15'"
        },
        "end_date": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 date, e.g. '2024-06-15'"
        }
      },
      "required": ["start_date", "end_date"]
    }
  }
}
