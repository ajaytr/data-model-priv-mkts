{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "money.schema.json",
  "title": "Money",
  "description": "Monetary amount with currency",
  "$defs": {
    "Money": {
      "type": "object",
      "description": "A monetary value represented as a decimal string to avoid floating-point issues",
      "properties": {
        "amount": {
          "type": "string",
          "pattern": "^-?\\d+(\\.\\d+)?$",
          "description": "Decimal amount as string to preserve precision"
        },
        "currency": {
          "$ref": "enums.schema.json#/$defs/Currency"
        }
      },
      "required": ["amount", "currency"]
    }
  }
}
