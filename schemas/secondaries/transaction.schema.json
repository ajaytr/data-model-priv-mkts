{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "transaction.schema.json",
  "title": "Transaction",
  "description": "Secondary transaction lifecycle",
  "$defs": {
    "TransactionMilestone": {
      "type": "object",
      "properties": {
        "stage": {
          "$ref": "enums.schema.json#/$defs/TransactionStage"
        },
        "date": {
          "$ref": "../core/dates.schema.json#/$defs/Date"
        },
        "completed": {
          "type": "boolean",
          "default": false
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "stage",
        "date"
      ]
    },
    "Transaction": {
      "allOf": [
        {
          "$ref": "../core/base.schema.json#/$defs/Auditable"
        },
        {
          "type": "object",
          "properties": {
            "trade_id": {
              "type": "string",
              "format": "uuid",
              "description": "Reference to SecondaryTrade"
            },
            "stage": {
              "$ref": "enums.schema.json#/$defs/TransactionStage"
            },
            "milestones": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/TransactionMilestone"
              }
            },
            "gp_consent_required": {
              "type": "boolean",
              "default": true
            },
            "gp_consent_received": {
              "type": "boolean",
              "default": false
            },
            "gp_consent_date": {
              "$ref": "../core/dates.schema.json#/$defs/Date"
            },
            "transfer_agent": {
              "type": "string",
              "format": "uuid",
              "description": "Reference to Party handling the transfer"
            },
            "legal_counsel_buyer": {
              "type": "string",
              "format": "uuid"
            },
            "legal_counsel_seller": {
              "type": "string",
              "format": "uuid"
            },
            "documents": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uuid"
              },
              "description": "References to Document entities"
            },
            "closing_date": {
              "$ref": "../core/dates.schema.json#/$defs/Date"
            },
            "effective_date": {
              "allOf": [
                {
                  "$ref": "../core/dates.schema.json#/$defs/Date"
                }
              ],
              "description": "Date the transfer becomes effective on the fund's books"
            }
          },
          "required": [
            "trade_id",
            "stage"
          ]
        }
      ]
    }
  }
}
