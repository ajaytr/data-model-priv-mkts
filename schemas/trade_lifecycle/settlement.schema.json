{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "settlement.schema.json",
  "title": "Settlement",
  "description": "Settlement instructions for trade execution",
  "$defs": {
    "SettlementInstruction": {
      "allOf": [
        { "$ref": "../core/base.schema.json#/$defs/Auditable" },
        {
          "type": "object",
          "properties": {
            "trade_id": {
              "type": "string",
              "format": "uuid",
              "description": "Reference to Trade"
            },
            "payment_amount": {
              "$ref": "../core/money.schema.json#/$defs/Money"
            },
            "settlement_date": {
              "type": "string",
              "format": "date",
              "description": "ISO 8601 date, e.g. '2024-06-15'"
            },
            "payer_id": {
              "type": "string",
              "format": "uuid",
              "description": "Reference to Party"
            },
            "payee_id": {
              "type": "string",
              "format": "uuid",
              "description": "Reference to Party"
            },
            "payment_method": {
              "type": "string",
              "enum": ["WIRE", "ACH", "CHECK", "DTC", "IN_KIND"]
            },
            "bank_name": { "type": "string" },
            "account_number": { "type": "string" },
            "routing_number": { "type": "string" },
            "swift_code": { "type": "string" },
            "reference": { "type": "string" },
            "status": {
              "type": "string",
              "enum": ["PENDING", "INSTRUCTED", "CONFIRMED", "SETTLED", "FAILED", "CANCELLED"]
            },
            "settled_at": {
              "allOf": [{ "$ref": "../core/dates.schema.json#/$defs/UtcDateTime" }],
              "description": "UTC timestamp when settlement was completed. Example: '2024-06-15T14:30:00Z'"
            }
          },
          "required": ["trade_id", "payment_amount", "settlement_date", "payer_id", "payee_id", "status"]
        }
      ]
    }
  }
}
